{
  "name": "VerificationRequest",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "selfie_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "reviewed_at": {
      "type": "string"
    },
    "rejection_reason": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "selfie_url"
  ]
}
